   "source": [
    "## conditional statement (if, elif, else)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fdb0adb2",
   "metadata": {},
   "outputs": [],
   "source": [
    "age = 20\n",
    "\n",
    "if age<13:\n",
    "    print(\"child\")\n",
    "elif age <18 :\n",
    "    print(\"teen ager\")\n",
    "else:\n",
    "    print(\"adult\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "aa7d7cd5",
   "metadata": {},
   "outputs": [],
   "source": [
    "num = int(input(\"write a int number\"))\n",
    "\n",
    "if num%2==0:\n",
    "    print(\"even\")\n",
    "else:\n",
    "    print(\"odd\")"
   ]
  },
  {
   "cell_type": "markdown",
